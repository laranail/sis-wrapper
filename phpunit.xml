<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         cacheDirectory=".phpunit.cache"
         failOnWarning="true"
         failOnRisky="true"
         beStrictAboutOutputDuringTests="true">
    <testsuites>
        <testsuite name="wrapper">
            <directory>tests</directory>
        </testsuite>
    </testsuites>
    <groups>
        <!-- The PostgreSQL trigger tests need a real server; the postgres.yml workflow opts in via the
             pgsql group. Excluded here so the default (SQLite) run stays clean. -->
        <exclude>
            <group>pgsql</group>
        </exclude>
    </groups>
    <source>
        <include>
            <directory>src</directory>
        </include>
    </source>
    <php>
        <!-- The default test cache store is the per-process `array` driver, which the schedule guard now
             rejects for onOneServer(). The scheduler is not under test in the general suite (ScheduleGuardTest
             covers the guard directly), so disable it here; individual tests re-enable it when they need it. -->
        <env name="SIS_SCHEDULE_ENABLED" value="false"/>
    </php>
</phpunit>
